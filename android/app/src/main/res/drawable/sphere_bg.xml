<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="oval">
            <gradient
                android:startColor="#FF2B465D"
                android:centerColor="#FF17293A"
                android:endColor="#FF0B1520"
                android:type="radial"
                android:gradientRadius="74%p" />
        </shape>
    </item>

    <item android:inset="2dp">
        <shape android:shape="oval">
            <stroke
                android:width="1.5dp"
                android:color="#80C1EAFF" />
            <solid android:color="#14000000" />
        </shape>
    </item>
</layer-list>
