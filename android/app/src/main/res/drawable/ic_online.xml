    <item>
        <shape android:shape="oval">
            <solid android:color="#2A4ADE80" />
            <size android:width="10dp" android:height="10dp" />
        </shape>
    </item>
    <item android:inset="2dp">
        <shape android:shape="oval">
            <solid android:color="#FF59E28A" />
            <stroke android:width="1dp" android:color="#FFA9F5C4" />
        </shape>
    </item>
</layer-list>
