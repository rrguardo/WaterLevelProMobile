<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:right="2dp">
        <shape android:shape="rectangle">
            <solid android:color="#1EFFE082" />
            <stroke android:width="1dp" android:color="#FFFFF2B8" />
            <corners android:radius="1.5dp" />
            <size android:width="12dp" android:height="8dp" />
        </shape>
    </item>

    <item android:left="2dp" android:top="2dp" android:right="5dp" android:bottom="2dp">
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#FFFFE082"
                android:endColor="#FFFFCA58"
                android:angle="0" />
            <corners android:radius="1dp" />
        </shape>
    </item>

    <item android:left="11dp" android:top="3dp" android:right="0dp" android:bottom="3dp">
        <shape android:shape="rectangle">
            <solid android:color="#FFFFE8A8" />
            <corners android:radius="1dp" />
            <size android:width="2dp" android:height="2dp" />
        </shape>
    </item>
</layer-list>
