<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="oval">
            <gradient
                android:startColor="#FF47EAFF"
                android:centerColor="#FF21A6FF"
                android:endColor="#FF0B57D0"
                android:angle="90"
                android:type="linear" />
        </shape>
    </item>
    <item android:insetTop="12dp">
        <shape android:shape="oval">
            <gradient
                android:startColor="#55FFFFFF"
                android:endColor="#00FFFFFF"
                android:angle="90"
                android:type="linear" />
        </shape>
    </item>
</layer-list>
