<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_bg">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_margin="16dp"
        android:layout_gravity="center">

        <ImageView
            android:id="@+id/sphere_bg"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/sphere_bg"
            android:scaleType="fitCenter" />

        <ImageView
            android:id="@+id/water_fill_view"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/water_clip"
            android:scaleType="fitCenter"
            android:contentDescription="Water level" />

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/sphere_highlight"
            android:scaleType="fitCenter"
            android:contentDescription="@null" />

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <TextView
                android:id="@+id/widget_percent"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:textColor="#FFFFFFFF"
                android:textSize="32sp"
                android:textStyle="bold"
                android:shadowColor="#90000000"
                android:shadowDx="0"
                android:shadowDy="2"
                android:shadowRadius="4"
                android:text="--%" />

            <TextView
                android:id="@+id/widget_subtext"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|center_horizontal"
                android:layout_marginBottom="16dp"
                android:textColor="#E0FFFFFF"
                android:textSize="12sp"
                android:textStyle="bold"
                android:shadowColor="#90000000"
                android:shadowDx="0"
                android:shadowDy="1"
                android:shadowRadius="3"
                android:visibility="gone"
                android:text="" />

        </FrameLayout>

    </FrameLayout>

    <TextView
        android:id="@+id/widget_branding"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="6dp"
        android:layout_marginBottom="4dp"
        android:textColor="#60FFFFFF"
        android:textSize="8sp"
        android:text="waterlevel.pro" />

</FrameLayout>
